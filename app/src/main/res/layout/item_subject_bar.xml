<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/bar_subject_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/on_background"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/bar_pct_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/bar_pct_text"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/bar_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:progress="0"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/outline_variant"
        app:trackCornerRadius="4dp"
        app:trackThickness="8dp"
        app:layout_constraintTop_toBottomOf="@id/bar_subject_text" />

</androidx.constraintlayout.widget.ConstraintLayout>
